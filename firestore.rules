rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.isAdmin == true;
    }

    function isSuspended(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && userDoc(uid).data.isSuspended == true;
    }

    function activeUser() {
      return signedIn() && !isSuspended(request.auth.uid);
    }

    function isParticipant() {
      return signedIn()
        && request.auth.uid in resource.data.participants;
    }

    function isRequestedParticipant() {
      return signedIn()
        && request.auth.uid in request.resource.data.participants;
    }

    function validLatLng(data) {
      return (!('latitude' in data) || data.latitude == null ||
          (data.latitude is number && data.latitude >= -90 && data.latitude <= 90))
        && (!('longitude' in data) || data.longitude == null ||
          (data.longitude is number && data.longitude >= -180 && data.longitude <= 180));
    }

    function validUserData(data, uid) {
      return data.keys().hasOnly([
          'uid', 'email', 'nickname', 'gender', 'lookingFor', 'createdAt',
          'latitude', 'longitude', 'city', 'state', 'country', 'photoUrl', 'age',
          'blockedUsers', 'lastSeen', 'isOnline', 'messageNotificationsEnabled',
          'nearbyAlertsEnabled', 'isAdmin', 'isSuspended'
        ])
        && data.uid == uid
        && (!('email' in data) || data.email is string)
        && (!('nickname' in data) || (data.nickname is string && data.nickname.size() > 0 && data.nickname.size() <= 30))
        && ('age' in data) && data.age is int && data.age >= 18 && data.age <= 99
        && (!('gender' in data) || data.gender in ['Male', 'Female', 'Other', 'Both', ''])
        && (!('lookingFor' in data) || data.lookingFor in ['Male', 'Female', 'Both', ''])
        && (!('blockedUsers' in data) || (data.blockedUsers is list && data.blockedUsers.size() <= 500))
        && (!('city' in data) || data.city == null || (data.city is string && data.city.size() <= 80))
        && (!('state' in data) || data.state == null || (data.state is string && data.state.size() <= 80))
        && (!('country' in data) || data.country == null || (data.country is string && data.country.size() <= 80))
        && (!('photoUrl' in data) || data.photoUrl == null || (data.photoUrl is string && data.photoUrl.size() <= 2048))
        && (!('isOnline' in data) || data.isOnline is bool)
        && (!('messageNotificationsEnabled' in data) || data.messageNotificationsEnabled is bool)
        && (!('nearbyAlertsEnabled' in data) || data.nearbyAlertsEnabled is bool)
        && validLatLng(data);
    }

    function validChatParticipants(participants) {
      return participants is list
        && participants.size() == 2
        && participants[0] is string
        && participants[1] is string
        && participants[0] != participants[1]
        && participants[0] < participants[1];
    }

    function otherParticipant(participants) {
      return participants[0] == request.auth.uid ? participants[1] : participants[0];
    }

    function validUnreadMaps(data, senderId, receiverId, receiverUnread) {
      return data.unreadCounts is map
        && data.unreadCounts.keys().hasOnly([senderId, receiverId])
        && data.unreadCounts[senderId] is int
        && data.unreadCounts[senderId] == 0
        && data.unreadCounts[receiverId] is int
        && data.unreadCounts[receiverId] == receiverUnread
        && receiverUnread >= 0
        && data.readStates is map
        && data.readStates.keys().hasOnly([senderId, receiverId])
        && data.readStates[senderId] is map
        && data.readStates[senderId].keys().hasOnly(['lastReadAt', 'lastReadMessageId', 'unreadCount'])
        && data.readStates[senderId].lastReadAt == request.time
        && data.readStates[senderId].lastReadMessageId is string
        && data.readStates[senderId].unreadCount == 0
        && data.readStates[receiverId] is map
        && data.readStates[receiverId].unreadCount is int
        && data.readStates[receiverId].unreadCount == receiverUnread;
    }

    function validReceiverReadStatePreserved(senderId, receiverId, receiverUnread) {
      let oldReadStates = resource.data.get('readStates', {});
      let oldReceiverState = oldReadStates.get(receiverId, {});
      let newReceiverState = request.resource.data.readStates[receiverId];
      return newReceiverState.diff(oldReceiverState).affectedKeys().hasOnly(['unreadCount'])
        && newReceiverState.unreadCount == receiverUnread;
    }

    function validMessageDeliveryState(chatId, existing) {
      let senderId = request.auth.uid;
      let receiverId = otherParticipant(request.resource.data.participants);
      let oldUnreadCounts = existing ? resource.data.get('unreadCounts', {}) : {};
      let receiverUnread = oldUnreadCounts.get(receiverId, 0) + 1;
      return validUnreadMaps(request.resource.data, senderId, receiverId, receiverUnread)
        && ((existing && validReceiverReadStatePreserved(senderId, receiverId, receiverUnread))
          || (!existing && request.resource.data.readStates[receiverId].keys().hasOnly(['unreadCount'])));
    }

    function validChatCreate(chatId) {
      return validChatParticipants(request.resource.data.participants)
        && chatId == request.resource.data.participants[0] + '_' + request.resource.data.participants[1]
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.keys().hasOnly(['participants', 'lastMessage', 'lastMessageTime', 'latestMessageAt', 'lastMessageSenderId', 'latestSenderId', 'lastMessageType', 'lastMessageIsUnsent', 'createdAt', 'unreadCounts', 'readStates'])
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() > 0
        && request.resource.data.lastMessage.size() <= 1000
        && request.resource.data.lastMessageSenderId == request.auth.uid
        && request.resource.data.latestSenderId == request.auth.uid
        && request.resource.data.lastMessageTime == request.time
        && request.resource.data.latestMessageAt == request.time
        && request.resource.data.createdAt == request.time
        && validMessageDeliveryState(chatId, false);
    }

    function validChatUpdate(chatId) {
      return validChatParticipants(request.resource.data.participants)
        && request.resource.data.participants == resource.data.participants
        && chatId == request.resource.data.participants[0] + '_' + request.resource.data.participants[1]
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastMessage', 'lastMessageTime', 'latestMessageAt', 'lastMessageSenderId', 'latestSenderId', 'lastMessageType', 'lastMessageIsUnsent', 'unreadCounts', 'readStates'])
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() > 0
        && request.resource.data.lastMessage.size() <= 1000
        && request.resource.data.lastMessageSenderId == request.auth.uid
        && request.resource.data.latestSenderId == request.auth.uid
        && request.resource.data.lastMessageTime == request.time
        && request.resource.data.latestMessageAt == request.time
        && validMessageDeliveryState(chatId, true);
    }

    function validReadStateUpdate() {
      let readerId = request.auth.uid;
      let otherId = otherParticipant(resource.data.participants);
      let oldUnreadCounts = resource.data.get('unreadCounts', {});
      let oldReadStates = resource.data.get('readStates', {});
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readStates', 'unreadCounts'])
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.unreadCounts is map
        && request.resource.data.unreadCounts.keys().hasOnly(resource.data.participants)
        && request.resource.data.unreadCounts[readerId] == 0
        && request.resource.data.unreadCounts[otherId] == oldUnreadCounts.get(otherId, 0)
        && request.resource.data.unreadCounts[otherId] is int
        && request.resource.data.unreadCounts[otherId] >= 0
        && request.resource.data.readStates is map
        && request.resource.data.readStates.keys().hasOnly(resource.data.participants)
        && request.resource.data.readStates[otherId] == oldReadStates.get(otherId, {})
        && request.resource.data.readStates[readerId] is map
        && request.resource.data.readStates[readerId].keys().hasOnly(['lastReadAt', 'lastReadMessageId', 'unreadCount'])
        && request.resource.data.readStates[readerId].unreadCount == 0
        && request.resource.data.readStates[readerId].lastReadAt == request.time;
    }

    function validAnnouncement(data) {
      return data.keys().hasOnly(['title', 'message', 'priority', 'type', 'targetAudience', 'isActive', 'createdByAdminId', 'createdAt', 'expiresAt', 'actionLabel', 'actionRoute', 'imageUrl'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 80
        && data.message is string && data.message.size() > 0 && data.message.size() <= 1000
        && data.priority in ['normal', 'important', 'urgent']
        && data.type == 'official_announcement'
        && data.targetAudience == 'allActiveUsers'
        && data.isActive is bool;
    }

    function validAnnouncementCreate() {
      return validAnnouncement(request.resource.data)
        && request.resource.data.createdByAdminId == request.auth.uid
        && request.resource.data.createdAt == request.time;
    }

    function validAnnouncementUpdate() {
      return validAnnouncement(request.resource.data)
        && request.resource.data.createdByAdminId == resource.data.createdByAdminId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isActive', 'expiresAt'])
        && resource.data.isActive == true
        && request.resource.data.isActive == false
        && request.resource.data.expiresAt == request.time;
    }

    function validNotificationReadUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt'])
        && request.resource.data.diff(resource.data).unchangedKeys().hasAll(resource.data.keys())
        && request.resource.data.readAt == request.time;
    }

    function canSendMessage(chatId) {
      return !exists(/databases/$(database)/documents/chats/$(chatId))
        || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function validMessageCreate(chatId, messageId) {
      let chat = getAfter(/databases/$(database)/documents/chats/$(chatId)).data;
      return request.resource.data.keys().hasOnly([
          'senderId', 'receiverId', 'text', 'timestamp', 'isUnsent', 'unsentAt',
          'replyToMessageId', 'replyToText', 'replyToSenderId', 'type', 'mediaUrl',
          'isSeen', 'seenAt', 'deletedFor'
        ])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId in chat.participants
        && request.resource.data.receiverId != request.auth.uid
        && request.auth.uid in chat.participants
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.timestamp == request.time
        && request.resource.data.isUnsent == false
        && request.resource.data.type == 'text'
        && request.resource.data.deletedFor == []
        && chat.lastMessageSenderId == request.auth.uid
        && chat.lastMessage == request.resource.data.text
        && chat.lastMessageTime == request.time
        && chat.readStates[request.auth.uid].lastReadMessageId == messageId
        && canSendMessage(chatId);
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || activeUser() || isAdmin());
      allow list: if (activeUser() && userDoc(request.auth.uid).data.age >= 18) || isAdmin();
      allow create: if signedIn()
        && request.auth.uid == userId
        && validUserData(request.resource.data, userId)
        && request.resource.data.isAdmin != true
        && request.resource.data.isSuspended != true
        && request.resource.data.age >= 18;
      allow update: if isAdmin()
        || (activeUser()
          && request.auth.uid == userId
          && validUserData(request.resource.data, userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isAdmin', 'isSuspended', 'createdAt', 'email', 'uid'])
          && request.resource.data.age >= 18);
      allow delete: if isAdmin() || (activeUser() && request.auth.uid == userId);
    }

    match /chats/{chatId} {
      allow read: if (activeUser() && isParticipant()) || isAdmin();
      allow create: if activeUser() && isRequestedParticipant() && validChatCreate(chatId);
      allow update: if (activeUser() && isParticipant() && validChatUpdate(chatId))
        || (activeUser() && isParticipant() && validReadStateUpdate())
        || isAdmin();
      allow delete: if (activeUser() && isParticipant()) || isAdmin();

      match /messages/{messageId} {
        allow read: if (activeUser()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
          || isAdmin();
        allow create: if activeUser() && validMessageCreate(chatId, messageId);
        allow update, delete: if (activeUser()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
          || isAdmin();
      }
    }

    match /supportAnnouncements/{announcementId} {
      allow read: if (activeUser()
        && resource.data.isActive == true
        && resource.data.targetAudience == 'allActiveUsers')
        || isAdmin();
      allow create: if isAdmin() && validAnnouncementCreate();
      allow update: if isAdmin() && validAnnouncementUpdate();
      allow delete: if false;
    }

    match /users/{userId}/privateState/{stateId} {
      allow read: if activeUser() && request.auth.uid == userId;
      allow create, update: if activeUser() && request.auth.uid == userId
        && stateId == 'supportAnnouncements'
        && request.resource.data.keys().hasOnly(['lastReadAt', 'updatedAt'])
        && request.resource.data.lastReadAt == request.time;
      allow delete: if false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if activeUser() && request.auth.uid == userId;
      allow create, delete: if isAdmin();
      allow update: if activeUser() && request.auth.uid == userId && validNotificationReadUpdate();
    }

    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if activeUser()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reportedUserId != request.auth.uid
        && request.resource.data.keys().hasOnly(['reporterId', 'reportedUserId', 'reporterName', 'reporterPhoto', 'reportedUserName', 'reportedUserPhoto', 'reason', 'description', 'status', 'createdAt', 'reviewedAt', 'reviewedBy', 'action'])
        && request.resource.data.reason in ['Spam', 'Fake Profile', 'Harassment', 'Hate Speech', 'Scam/Fraud', 'Inappropriate Content', 'Other']
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
